# Copy to .env and fill in. Never commit .env.
#
# The MemOpt engine ships as a container image in a PRIVATE registry — pull access is
# the IP boundary (the image bakes the Python source; only authorized people may pull).
# `docker login` first; see ENABLE_MEMOPT.md.
# TEMP: personal GHCR namespace (org package-create not yet granted). Move to
# ghcr.io/chaosxingxc-orion/memopt:0.0.1 once the org grants it.
MEMOPT_IMAGE=ghcr.io/kevin-708090/memopt:0.0.1
# Harbor: MEMOPT_IMAGE=harbor.example.com/memopt/memopt:0.0.1

# --- required: the LLM gateway the MemOpt engine calls ---
GATEWAY_BASE_URL=
GATEWAY_API_KEY=
DEFAULT_MODEL=

# --- optional ---
CHROMA_EMBEDDING_MODEL=
MEMOPT_JUDGE_MODEL=
MEMOPT_PORT=8077

# Gate /v1/* behind a bearer token (recommended whenever MemOpt is reachable beyond
# localhost). The A2A kit MUST send the same token — see ENABLE_MEMOPT.md.
MEMOPT_FACADE_AUTH_TOKEN=

<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{HH:mm:ss} %-5level %logger{0} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 只保留 WARN 及以上，屏蔽框架刷屏的 INFO 日志，让控制台只剩干净的方案输出 -->
    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>

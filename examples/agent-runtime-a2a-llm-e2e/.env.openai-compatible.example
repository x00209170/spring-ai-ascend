# Cloud OpenAI-compatible API (OpenAI / a LiteLLM gateway / Azure-OpenAI-compat / ...).
# Do NOT commit your real key — copy to `.env` and put the key THERE (.env is gitignored).
#   bash scripts/test-e2e.sh .env
SAA_SAMPLE_LLM_API_KEY=sk-REPLACE-ME
SAA_SAMPLE_OPENJIUWEN_MODEL_PROVIDER=openai
SAA_SAMPLE_OPENJIUWEN_API_BASE=https://api.openai.com/v1
SAA_SAMPLE_AGENTSCOPE_API_BASE=https://api.openai.com/v1
SAA_SAMPLE_AGENTSCOPE_ENDPOINT_PATH=/chat/completions
SAA_SAMPLE_LLM_MODEL=gpt-4o-mini
SAA_SAMPLE_OPENJIUWEN_SSL_VERIFY=true
SAA_SAMPLE_AGENTSCOPE_RUNTIME_BASE_URL=self
SAA_SAMPLE_RETAIL_WEALTH_RUNTIME_BASE_URL=self
SAA_SAMPLE_GATEWAY_ROUTE_GRANT_SECRET=replace-with-a-non-default-secret

# Spring AI Ascend — agent-runtime-a2a-llm-e2e sample configuration.
# Copy to `.env` (gitignored) and fill in your model service, then run:
#   bash scripts/test-e2e.sh .env            (Linux/WSL/macOS)
#   ./scripts/test-e2e.ps1 -EnvFile .env     (Windows PowerShell)
#
# IMPORTANT: the real-LLM E2E tests only run when SAA_SAMPLE_LLM_API_KEY is
# non-blank. Without it, JUnit assumeTrue() SKIPS the real-LLM branch after
# the agent-card check (the rest of the suite still runs).

# Any non-blank value enables the real-LLM E2E branch (use your provider's key/token).
SAA_SAMPLE_LLM_API_KEY=
# Base URL of an OpenAI-compatible endpoint.
SAA_SAMPLE_AGENTSCOPE_API_BASE=http://localhost:4000/v1
# AgentScope OpenAI-compatible chat-completions path.
SAA_SAMPLE_AGENTSCOPE_ENDPOINT_PATH=/chat/completions
# Model name served by that endpoint.
SAA_SAMPLE_LLM_MODEL=gpt-5.4-mini
# Optional external AgentScope REST/SSE runtimes. Leave `self` for embedded samples.
SAA_SAMPLE_AGENTSCOPE_RUNTIME_BASE_URL=self
SAA_SAMPLE_RETAIL_WEALTH_RUNTIME_BASE_URL=self

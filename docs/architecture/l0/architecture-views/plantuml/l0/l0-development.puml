title L0 Development View - Repository Modules Supporting the Six Capabilities

' rc13 (ADR-0088): rewritten to current 8-module reactor — Phase C consolidated
' agent-platform + agent-runtime into agent-service per ADR-0078; ADR-0079
' transiently extracted agent-runtime-core; rc13 dissolved agent-runtime-core
' per ADR-0088 and redistributed its sources back to agent-service (runs +
' idempotency) + agent-bus (bus.spi.s2c). ADR-0158 then re-homed the neutral
' orchestration/engine SPI to agent-bus (bus.spi.engine: EnginePort + RunMode +
' orchestration types). Paired with ADR-0089 which adds agent-bus
' bus.spi.ingress.IngressGateway as the C2S cross-plane control surface.

System_Boundary(repo, "Current repository modules") {
  Container(agent_service, "agent-service", "Maven module", "Northbound HTTP facade + Spring Boot bootstrap + tenant filter + idempotency + posture gate + reference orchestrator wiring + Run/RunStateMachine/IdempotencyRecord entities + memory/resilience/runs SPIs (rc13 re-consolidation per ADR-0088).", $tags="S-Side")
  Container(agent_execution_engine, "agent-execution-engine", "Maven module", "Execution adapter SPI (engine.spi: ExecutorAdapter / EngineRegistry / EngineEnvelope) + InProcessEnginePort realization of the neutral EnginePort boundary (ADR-0158).", $tags="S-Side")
  Container(agent_middleware_module, "agent-middleware", "Maven module", "Runtime-owned cross-cutting middleware SPI (HookPoint / RuntimeMiddleware / HookContext / HookOutcome / HookDispatcher) per ADR-0073.", $tags="S-Side")
  Container(agent_bus_module, "agent-bus", "Maven module", "Bus & State Hub plane — cross-plane control surfaces in BOTH directions: bus.spi.ingress.IngressGateway (ADR-0089) + bus.spi.s2c.S2cCallbackTransport (ADR-0074 + ADR-0088) + neutral orchestration/engine SPI bus.spi.engine (EnginePort / RunMode / Checkpointer / Orchestrator / RunContext / SuspendSignal / TraceContext / ExecutorDefinition / ExecutionContext per ADR-0158). Workflow primitives W2 per ADR-0050.", $tags="S-Side")
  Container(agent_client_module, "agent-client", "Maven module", "Edge Access plane skeleton (AgentClient SDK + Task Cursor consumer + SSE/Webhook receiver). W3+ per ADR-0049. Cross-plane traffic locked to bus.spi.ingress.IngressGateway per ADR-0089 / Rule R-I.b.", $tags="C-Side")
  Container(agent_evolve_module, "agent-evolve", "Maven module", "Evolution plane Java-side adapter skeleton. Bulk implementation deferred per ADR-0075.", $tags="S-Side")
  Container(dependencies_bom, "spring-ai-ascend-dependencies", "Maven BOM", "Dependency pinning and build alignment across the eight reactor modules.", $tags="Governance")
  Container(graphmemory, "spring-ai-ascend-graphmemory-starter", "Spring starter", "Graph memory starter and adapter shell.", $tags="S-Side")
}

System_Boundary(l0_caps, "L0 capability labels") {
  Container(agent_client, $AGENT_CLIENT_NAME, "Capability", $AGENT_CLIENT_DESC, $tags="C-Side", $link=$L1_AGENT_CLIENT)
  Container(agent_service_cap, $AGENT_SERVICE_NAME, "Capability", $AGENT_SERVICE_DESC, $tags="S-Side", $link=$L1_AGENT_SERVICE)
  Container(exec_engine, $EXECUTION_ENGINE_NAME, "Capability", $EXECUTION_ENGINE_DESC, $tags="S-Side", $link=$L1_EXECUTION_ENGINE)
  Container(agent_bus, $AGENT_BUS_NAME, "Capability", $AGENT_BUS_DESC, $tags="S-Side", $link=$L1_AGENT_BUS)
  Container(agent_middleware, $AGENT_MIDDLEWARE_NAME, "Capability", $AGENT_MIDDLEWARE_DESC, $tags="S-Side", $link=$L1_AGENT_MIDDLEWARE)
  Container(evolution, $EVOLUTION_NAME, "Capability", $EVOLUTION_DESC, $tags="S-Side", $link=$L1_EVOLUTION)
}

Rel(agent_service, agent_service_cap, "implements the northbound HTTP edge + runtime wiring + runs/idempotency entities")
Rel(agent_execution_engine, exec_engine, "implements execution adapter SPI + orchestration SPI")
Rel(agent_middleware_module, agent_middleware, "implements runtime-owned cross-cutting middleware SPI")
Rel(agent_bus_module, agent_bus, "owns ingress (C2S) + s2c (S2C) cross-plane control surfaces")
Rel(agent_client_module, agent_client, "skeleton for Edge Access SDK; consumes bus.spi.ingress.IngressGateway")
Rel(agent_evolve_module, evolution, "Java adapter shell for evolution plane")
Rel(graphmemory, agent_middleware, "contributes memory adapter shell")
Rel(dependencies_bom, agent_service, "pins dependency versions")
Rel(dependencies_bom, agent_execution_engine, "pins dependency versions")
Rel(dependencies_bom, agent_middleware_module, "pins dependency versions")
Rel(dependencies_bom, agent_bus_module, "pins dependency versions")
Rel(dependencies_bom, agent_client_module, "pins dependency versions")
Rel(dependencies_bom, agent_evolve_module, "pins dependency versions")
Rel(dependencies_bom, graphmemory, "pins dependency versions")

note bottom of repo
Development red lines:
- Core/runtime contracts do not depend on business applications.
- Core/runtime contracts do not directly bind to concrete middleware implementations.
- Middleware implementations are injected through service/runtime adapters.
- The evolution layer is isolated from the Java service/execution path through bus or serialized contracts.
- Edge plane (agent-client) MUST NOT directly import compute_control plane production code; cross-plane traffic flows through agent-bus.spi.ingress.IngressGateway (Rule R-I.b / ADR-0089).
- This view stays at module direction, not class or interface internals.
- Pre-Phase-C modules agent-platform/agent-runtime consolidated per ADR-0078; transient agent-runtime-core dissolved per rc13 ADR-0088.
end note

